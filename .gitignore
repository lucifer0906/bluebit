# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/
env/
.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# Distribution / packaging
*.egg-info/
dist/
build/

# Jupyter
.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db

# --- Machine Learning / Data Science ---

# Model weights and artifacts
models/*.pkl
models/*.joblib
models/*.pth
models/*.pt
models/*.h5
models/*.bin
models/*.onnx
models/*.keras
models/*.weights
models/*.tflite
models/*.pb
!models/.gitkeep

# Datasets (large files)
data/*.csv
data/*.jsonl
data/*.parquet
data/*.arrow
data/*.hdf5
data/*.npy
data/*.npz
data/processed/
data/raw/
!data/.gitkeep

# Modal specific
.modal/
modal.log

# Test results
tests/test_results/*.html
!tests/test_results/.gitkeep
